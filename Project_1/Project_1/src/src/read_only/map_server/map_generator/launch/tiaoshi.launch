<launch>
    <!-- ============================================ -->
    <!-- 地图参数配置 -->
    <!-- ============================================ -->
    <arg name="map_size_x" default="30.0"/>
    <!-- 地图X轴尺寸（米） -->
    <arg name="map_size_y" default="30.0"/>
    <!-- 地图Y轴尺寸（米） -->
    <arg name="map_size_z" default="4.0"/>
    <!-- 地图Z轴尺寸（米） -->
    <arg name="map_frame_name" default="world"/>
    <!-- 地图坐标系名称 -->

    <!-- ============================================ -->
    <!-- 初始位置配置 -->
    <!-- ============================================ -->
    <arg name="start_x" default="-15.0"/>
    <!-- 起始X坐标（米） -->
    <arg name="start_y" default="0.0"/>
    <!-- 起始Y坐标（米） -->
    <arg name="start_z" default="2.0"/>
    <!-- 起始Z坐标（米） -->

    <!-- ============================================ -->
    <!-- 障碍物参数配置 -->
    <!-- ============================================ -->
    <arg name="static_obs_num" default="30"/>
    <!-- 静态障碍物数量 -->
    <arg name="dynamic_obs_enabled" default="true"/>
    <!-- 是否启用动态障碍物 -->
    <arg name="dynamic_obs_num" default="3"/>
    <!-- 动态障碍物数量 -->
    <arg name="dynamic_update_rate" default="200.0"/>
    <!-- 动态障碍物更新频率（Hz） -->

    <!-- ============================================ -->
    <!-- 传感器参数配置 -->
    <!-- ============================================ -->
    <arg name="sensing_horizon" default="5.0"/>
    <!-- 传感器感知范围（米） -->
    <arg name="sensing_rate" default="30.0"/>
    <!-- 传感器采样频率（Hz） -->
    <arg name="estimation_rate" default="30.0"/>
    <!-- 状态估计频率（Hz） -->

    <!-- ============================================ -->
    <!-- 随机地图生成器节点 -->
    <!-- ============================================ -->
    <node pkg="map_generator" name="random_complex" type="random_complex" output="screen">
    
    <!-- 初始状态参数 -->
    <param name="init_state_x" value="$(arg start_x)"/>
    <!-- 初始X坐标 -->
    <param name="init_state_y" value="$(arg start_y)"/>
    <!-- 初始Y坐标 -->

    <!-- 地图尺寸参数 -->
    <param name="map/x_size" value="$(arg map_size_x)"/>
    <!-- 地图X轴尺寸 -->
    <param name="map/y_size" value="$(arg map_size_y)"/>
    <!-- 地图Y轴尺寸 -->
    <param name="map/z_size" value="$(arg map_size_z)"/>
    <!-- 地图Z轴尺寸 -->
    <param name="map_frame_name" value="$(arg map_frame_name)"/>
    <!-- 地图坐标系名称 -->

    <!-- 障碍物数量参数 -->
    <param name="map/obs_num" value="$(arg static_obs_num)"/>
    <!-- 静态障碍物数量 -->
    <param name="map/circle_num" value="0"/>
    <!-- 圆形障碍物数量（设为0表示不使用） -->
    <param name="map/resolution" value="0.1"/>
    <!-- 地图分辨率（米） - 提高分辨率使运动更流畅 -->

    <!-- 障碍物形状参数（匹配pine_tree模型） -->
    <param name="ObstacleShape/lower_rad" value="0.5"/>
    <!-- 障碍物最小半径（米） - 匹配pine_tree树干半径 -->
    <param name="ObstacleShape/upper_rad" value="1.5"/>
    <!-- 障碍物最大半径（米） - 匹配pine_tree树冠半径 -->
    <param name="ObstacleShape/lower_hei" value="2.0"/>
    <!-- 障碍物最小高度（米） - 降低高度使树干底部在地面 -->
    <param name="ObstacleShape/upper_hei" value="4.0"/>
    <!-- 障碍物最大高度（米） - 降低高度使树干底部在地面 -->

    <!-- 障碍物形状参数（圆形） -->
    <param name="CircleShape/lower_circle_rad" value="0.3"/>
    <!-- 圆形障碍物最小半径（米） -->
    <param name="CircleShape/upper_circle_rad" value="0.8"/>
    <!-- 圆形障碍物最大半径（米） -->

    <!-- 传感器和动态障碍物参数 -->
    <param name="sensing/rate" value="100.0"/>
    <!-- 传感器采样频率（Hz） - 影响点云更新频率 -->
    <param name="dynamic_obstacles" value="$(arg dynamic_obs_enabled)"/>
    <!-- 是否启用动态障碍物 -->
    <param name="dynamic_obstacles_num" value="$(arg dynamic_obs_num)"/>
    <!-- 动态障碍物数量 -->
    <param name="dynamic_update_rate" value="$(arg dynamic_update_rate)"/>
    <!-- 动态障碍物更新频率（Hz） - 影响动态障碍物运动流畅度 -->
    </node>
</launch>